        round(avg(shot_distance), 1)                as avg_shot_distance
    from `nbaanalyzer`.`nba_analytics_dev_staging`.`stg_shots`
    group by team_id

)

select
    t.team_id,
    t.team_name,
    s.team_fga,
    s.team_fgm,
    s.team_fg_pct,
    s.roster_size,
    s.games_played,
    s.avg_shot_distance
from team_source t
inner join team_stats s using (team_id)
    );
  
